/* ==========================================================================
 *  GciEncrypt
 *  Encrypts the clear text 'password'. Puts the encrypted form in
 *  outBuff and returns a pointer to the first character.
 *  Returns NULL if outBuff is not large enough.
 *
 *  The password argument uses 8 bit code points in the range
 *  1 to 255 (ISO-Latin1 character set,
 *  http://www.unicode.org/charts/PDF/U0080.pdf)
 */
  EXTERN_GCI_DEC(char*)
GciEncrypt(const char* password,
	   char outBuff[],
	   unsigned int outBuffSize)  GCI_WEAK;

