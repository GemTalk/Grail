/* ==========================================================================
 * GciLoginEx
 * same as GciLogin except it supports loginFlags amd haltOnErrNum.
 * loginFlags is a bit set. Legal bits are GCI_LOGIN_*.
 * haltOnErrNum argument is error to halt on. -1 means retain the config
 * setting; 0 means never halt.
 * GciLoginEx_ variant returns TRUE in *executedSessionInit
 *   if succeeded and VM executed   GsCurrentSession initialize .
 */
  GCI_ALIGN_STACK EXTERN_GCI_DEC(BoolType)
GciLoginEx(
  const char gemstoneUsername[], const char gemstonePassword[],
  unsigned int loginFlags, int haltOnErrNum
  )  GCI_WEAK;

