 * GciNbAbort function
 *   Abort the current transaction (nonblocking).
 *  client user actions not supported, implementation sets flag GCI_PERFORM_noClientUseraction
 *==============================================================================
 */
  EXTERN_GCI_DEC(void)
GciNbAbort(void)  GCI_WEAK;

