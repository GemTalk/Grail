#!/bin/bash

if [ ! -f .setenv ]; then
    cp scripts/setenv .setenv
fi
source .setenv
if [ ! -f ~/.topazini ]; then
    cp scripts/topazini ~/.topazini
fi

# Usage
#   grail  <path to python file to run>
#
#   grail  -m  <dotted.module.name>
#      run a module by name as __main__ (like: python3 -m dotted.module.name)
#
#   grail  -D  <path to python file to run>
#      run specified file and if interactive, pass errors to topaz for interactive debug
#
#  For gem configuration, create a gem.conf in current directory 
#  or edit this script to add a -T or -C  argument before the -S .

topaz -lq -S scripts/grail.tpz -T 400000 -C "GEM_TEMPOBJ_CODE_SIZE=300000;" -- $*
