! ------------------- Remove existing behavior from PyUSub
expectvalue /Metaclass3       
doit
PyUSub removeAllMethods.
PyUSub class removeAllMethods.
%
! ------------------- Class methods for PyUSub
! ------------------- Instance methods for PyUSub
set compile_env: 0
category: 'other'
method: PyUSub
operand: operand
	^operand evaluate negated
%
